# Copy to .env and source it before running Terraform:
#   source .env && terraform apply
#
# .env is gitignored — never commit it.

export TF_VAR_proxmox_password="your-proxmox-root-password"
export TF_VAR_ssh_public_key="ssh-ed25519 AAAA... your@email.com"
export TF_VAR_vm_password="your-vm-ubuntu-password"
